{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "diffsmith review findings",
  "type": "object",
  "additionalProperties": false,
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "file",
          "line",
          "severity",
          "title",
          "evidence",
          "suggested_comment",
          "fix_hint",
          "confidence"
        ],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low", "suggestion"]
          },
          "title": { "type": "string" },
          "evidence": { "type": "string" },
          "suggested_comment": { "type": "string", "minLength": 1 },
          "fix_hint": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
